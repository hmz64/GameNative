<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <!-- Main Game Content -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

        <!-- Question Number -->
        <TextView
            android:id="@+id/tvQuestionNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Question 1/10"
            android:textSize="16sp"
            android:textColor="#AAAAAA"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Timer -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:gravity="center"
            android:text="15"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/timer_background"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Progress Timer -->
        <ProgressBar
            android:id="@+id/progressTimer"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_marginTop="16dp"
            android:max="15"
            android:progress="15"
            android:progressTint="#E94560"
            android:progressBackgroundTint="#333333"
            app:layout_constraintTop_toBottomOf="@id/tvTimer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Question Text -->
        <TextView
            android:id="@+id/tvQuestion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Question goes here..."
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:textAlignment="center"
            android:lineSpacingExtra="4dp"
            app:layout_constraintTop_toBottomOf="@id/progressTimer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Score Info -->
        <TextView
            android:id="@+id/tvScoreInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Score: 0"
            android:textSize="16sp"
            android:textColor="#FFC107"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tvQuestion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Answer Buttons -->
        <Button
            android:id="@+id/btnOptionA"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:text="A. Option"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#6200EE"
            android:textAllCaps="false"
            app:cornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvScoreInfo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnOptionB"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:text="B. Option"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#6200EE"
            android:textAllCaps="false"
            app:cornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/btnOptionA"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnOptionC"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:text="C. Option"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#6200EE"
            android:textAllCaps="false"
            app:cornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/btnOptionB"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnOptionD"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:text="D. Option"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#6200EE"
            android:textAllCaps="false"
            app:cornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/btnOptionC"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Leaderboard Overlay -->
    <LinearLayout
        android:id="@+id/layoutLeaderboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Leaderboard"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFC107" />

        <TextView
            android:id="@+id/tvLeaderboardContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:lineSpacingExtra="8dp"
            android:fontFamily="monospace" />

    </LinearLayout>

</FrameLayout>
